    "View": {
      "type": "object",
      "properties": {
        "columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Column"
          }
        },
        "comment": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "schema": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "schema",
        "columns"
      ]
    }
  }
}