        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "boolean"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "int16"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "int32"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "int64"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "float32"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "float64"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "decimal"
            },
            "value": {
              "type": "object",
              "properties": {
                "precision": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "uint32",
                  "minimum": 0
                },
                "scale": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "uint32",
                  "minimum": 0
                }
              }
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "char"
            },
            "value": {
              "type": "object",
              "properties": {
                "len": {
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0
                }
              },
              "required": [
                "len"
              ]
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "text"
            },
            "value": {
              "type": "object",
              "properties": {
                "max_len": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "uint32",
                  "minimum": 0
                }
              }
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "uuid"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "json"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "bytes"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "date"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "time"
            },
            "value": {
              "type": "object",
              "properties": {
                "precision": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "uint32",
                  "minimum": 0
                }
              }
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "timestamp"
            },
            "value": {
              "type": "object",
              "properties": {
                "precision": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "uint32",
                  "minimum": 0
                },
                "tz": {
                  "type": "boolean"
                }
              },
              "required": [
                "tz"
              ]
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "other"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        }
      ]
    },
    "Schema": {
      "type": "object",
      "properties": {
        "composites": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Composite"
          }
        },
        "domains": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Domain"
          }
        },
        "enums": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Enum"
          }
        },
        "name": {
          "type": "string"
        },
        "tables": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Table"
          }
        },
        "views": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/View"
          }
        }
      },
      "required": [
        "name",
        "tables",
        "enums",
        "views",
        "composites",
        "domains"
      ]
    },
    "Table": {
      "type": "object",
      "properties": {
        "columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Column"
          }
        },
        "comment": {
          "type": [
            "string",
            "null"
          ]
        },
        "foreign_keys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ForeignKey"
          }
        },
        "name": {
          "type": "string"
        },
        "primary_key": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schema": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "schema",
        "columns",
        "primary_key",
        "foreign_keys"
      ]
